{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — TaskFlow{% endblock %}

{% block body %}
<div class="space-y-8">

    {# Header #}
    <div class="flex items-center justify-between">
        <div>
            <h1>Tableau de bord</h1>
            <p class="text-gray-500 text-sm mt-1">Bonjour ! Voici un résumé de vos tâches.</p>
        </div>
        <a href="{{ path('app_task_new') }}" class="btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouvelle tâche
        </a>
    </div>

    {# Stat cards #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="stat-card">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-gray-500">Total</p>
                <div class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-bold text-gray-900 mt-2">{{ statusCounts.total }}</p>
            <p class="text-xs text-gray-400 mt-1">tâches au total</p>
        </div>

        <div class="stat-card">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-gray-500">À faire</p>
                <div class="w-9 h-9 rounded-lg bg-slate-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-bold text-slate-700 mt-2">{{ statusCounts.todo }}</p>
            <a href="{{ path('app_task_index', {status: 'todo'}) }}" class="text-xs text-slate-500 hover:text-slate-700 mt-1 inline-block transition-colors">Voir les tâches →</a>
        </div>

        <div class="stat-card">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-gray-500">En cours</p>
                <div class="w-9 h-9 rounded-lg bg-blue-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-bold text-blue-700 mt-2">{{ statusCounts.in_progress }}</p>
            <a href="{{ path('app_task_index', {status: 'in_progress'}) }}" class="text-xs text-blue-500 hover:text-blue-700 mt-1 inline-block transition-colors">Voir les tâches →</a>
        </div>

        <div class="stat-card">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-gray-500">Terminées</p>
                <div class="w-9 h-9 rounded-lg bg-green-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-bold text-green-700 mt-2">{{ statusCounts.done }}</p>
            <a href="{{ path('app_task_index', {status: 'done'}) }}" class="text-xs text-green-500 hover:text-green-700 mt-1 inline-block transition-colors">Voir les tâches →</a>
        </div>
    </div>

    {# Barre de progression globale #}
    {% if statusCounts.total > 0 %}
    <div class="card p-6">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-base font-semibold text-gray-900">Progression globale</h2>
            <span class="text-sm font-medium text-gray-500">
                {{ statusCounts.done }} / {{ statusCounts.total }} terminées
            </span>
        </div>
        {% set progress = (statusCounts.done / statusCounts.total * 100)|round %}
        <div class="h-2.5 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-primary-500 to-green-500 rounded-full transition-all duration-500"
                 style="width: {{ progress }}%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-2">{{ progress }}% de complétion</p>
    </div>
    {% endif %}

    {# Priorités #}
    {% set priorityItems = [
        {value: 'high',   label: 'Haute priorité',   colorClass: 'text-red-600 bg-red-50 border-red-100'},
        {value: 'medium', label: 'Priorité moyenne',  colorClass: 'text-amber-600 bg-amber-50 border-amber-100'},
        {value: 'low',    label: 'Faible priorité',   colorClass: 'text-emerald-600 bg-emerald-50 border-emerald-100'},
    ] %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        {% for item in priorityItems %}
        <div class="card p-4 border {{ item.colorClass }} flex items-center justify-between">
            <div>
                <p class="text-sm font-medium">{{ item.label }}</p>
                <p class="text-2xl font-bold mt-0.5">{{ attribute(priorityCounts, item.value) }}</p>
            </div>
            <a href="{{ path('app_task_index', {priority: item.value}) }}"
               class="text-xs font-medium hover:underline">Voir →</a>
        </div>
        {% endfor %}
    </div>

    {# Tâches récentes #}
    <div>
        <div class="flex items-center justify-between mb-4">
            <h2>Tâches récentes</h2>
            <a href="{{ path('app_task_index') }}" class="text-sm text-primary-600 hover:text-primary-700 font-medium transition-colors">
                Voir toutes →
            </a>
        </div>

        {% if recentTasks is empty %}
            <div class="card p-12 text-center">
                <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                </div>
                <p class="text-gray-500 mb-4">Aucune tâche pour le moment.</p>
                <a href="{{ path('app_task_new') }}" class="btn-primary">Créer une tâche</a>
            </div>
        {% else %}
            <div class="card divide-y divide-gray-50">
                {% for task in recentTasks %}
                <div class="flex items-center gap-4 p-4 hover:bg-gray-50/50 transition-colors">
                    <div class="w-2 h-2 rounded-full shrink-0 {{ task.priority.dotClass() ?? 'bg-gray-300' }}"></div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-900 truncate {{ task.isDone() ? 'line-through text-gray-400' : '' }}">
                            {{ task.title }}
                        </p>
                        <p class="text-xs text-gray-400 mt-0.5">{{ task.createdAt|date('d/m/Y') }}</p>
                    </div>
                    <span class="badge shrink-0 {{ task.status.colorClass() }}">
                        {{ task.status.label() }}
                    </span>
                    <a href="{{ path('app_task_show', {id: task.id}) }}"
                       class="btn-ghost btn-sm shrink-0">
                        Voir
                    </a>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
