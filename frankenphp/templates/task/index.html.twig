{% extends 'base.html.twig' %}

{% block title %}Mes tâches — TaskFlow{% endblock %}

{% block body %}
<div class="space-y-6">

    {# Header #}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1>Mes tâches</h1>
            <p class="text-gray-500 text-sm mt-1">{{ tasks|length }} tâche{{ tasks|length != 1 ? 's' : '' }}
                {% if currentStatus or currentPriority %} filtrée{{ tasks|length != 1 ? 's' : '' }}{% endif %}
            </p>
        </div>
        <a href="{{ path('app_task_new') }}" class="btn-primary self-start sm:self-auto">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouvelle tâche
        </a>
    </div>

    {# Filtres #}
    <div class="card p-4 space-y-3">
        <div class="flex flex-wrap gap-2 items-center">
            <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide w-full sm:w-auto">Statut</span>
            <a href="{{ path('app_task_index', {priority: currentPriority}) }}"
               class="filter-pill {{ not currentStatus ? 'filter-pill-active' : 'filter-pill-inactive' }}">
                Tous
            </a>
            {% for status in ['todo', 'in_progress', 'done'] %}
            {% set labels = {todo: 'À faire', in_progress: 'En cours', done: 'Terminé'} %}
            <a href="{{ path('app_task_index', {status: status, priority: currentPriority}) }}"
               class="filter-pill {{ currentStatus == status ? 'filter-pill-active' : 'filter-pill-inactive' }}">
                {{ labels[status] }}
            </a>
            {% endfor %}
        </div>
        <div class="flex flex-wrap gap-2 items-center border-t border-gray-50 pt-3">
            <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide w-full sm:w-auto">Priorité</span>
            <a href="{{ path('app_task_index', {status: currentStatus}) }}"
               class="filter-pill {{ not currentPriority ? 'filter-pill-active' : 'filter-pill-inactive' }}">
                Toutes
            </a>
            {% for priority in ['low', 'medium', 'high'] %}
            {% set labels = {low: 'Faible', medium: 'Moyenne', high: 'Haute'} %}
            <a href="{{ path('app_task_index', {status: currentStatus, priority: priority}) }}"
               class="filter-pill {{ currentPriority == priority ? 'filter-pill-active' : 'filter-pill-inactive' }}">
                {{ labels[priority] }}
            </a>
            {% endfor %}
        </div>
        {% if currentStatus or currentPriority %}
        <div class="border-t border-gray-50 pt-3">
            <a href="{{ path('app_task_index') }}" class="text-xs text-gray-500 hover:text-gray-700 transition-colors">
                ✕ Effacer les filtres
            </a>
        </div>
        {% endif %}
    </div>

    {# Task grid #}
    {% if tasks is empty %}
        <div class="card p-16 text-center">
            <div class="w-20 h-20 bg-gray-100 rounded-3xl flex items-center justify-center mx-auto mb-5">
                <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                </svg>
            </div>
            {% if currentStatus or currentPriority %}
                <p class="text-gray-500 font-medium mb-2">Aucune tâche ne correspond aux filtres</p>
                <a href="{{ path('app_task_index') }}" class="text-sm text-primary-600 hover:text-primary-700">Effacer les filtres</a>
            {% else %}
                <p class="text-gray-500 font-medium mb-4">Aucune tâche pour le moment</p>
                <a href="{{ path('app_task_new') }}" class="btn-primary">Créer une tâche</a>
            {% endif %}
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            {% for task in tasks %}
                {% include 'task/_card.html.twig' with {task: task} %}
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
