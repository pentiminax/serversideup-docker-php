{% extends 'base.html.twig' %}

{% block title %}{{ task.title }} — TaskFlow{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto space-y-6">

    {# Breadcrumb #}
    <nav class="flex items-center gap-2 text-sm text-gray-500" aria-label="Fil d'Ariane">
        <a href="{{ path('app_task_index') }}" class="hover:text-gray-700 transition-colors">Tâches</a>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-900 font-medium truncate">{{ task.title }}</span>
    </nav>

    {# Card principale #}
    <div class="card border-l-4 {{ task.priority.borderClass() }} p-6 space-y-5 {{ task.isDone() ? 'opacity-75' : '' }}">

        {# Header #}
        <div class="flex items-start justify-between gap-4">
            <div class="space-y-2">
                <div class="flex flex-wrap gap-2">
                    <span class="badge {{ task.status.colorClass() }}">
                        <span class="w-1.5 h-1.5 rounded-full {{ task.status.dotClass() }}"></span>
                        {{ task.status.label() }}
                    </span>
                    <span class="badge {{ task.priority.colorClass() }}">{{ task.priority.label() }}</span>
                    {% if task.isOverdue() %}
                        <span class="badge bg-red-100 text-red-700">En retard</span>
                    {% endif %}
                </div>
                <h1 class="{{ task.isDone() ? 'line-through text-gray-400' : '' }}">{{ task.title }}</h1>
            </div>

            {# Toggle done #}
            <form action="{{ path('app_task_toggle', {id: task.id}) }}" method="post">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle-task-' ~ task.id) }}">
                <button type="submit"
                        class="w-10 h-10 rounded-full border-2 flex items-center justify-center shrink-0 transition-all duration-200
                               {{ task.isDone() ? 'bg-green-500 border-green-500 text-white' : 'border-gray-200 text-transparent hover:border-green-400 hover:text-green-400' }}"
                        aria-label="{{ task.isDone() ? 'Marquer comme à faire' : 'Marquer comme terminé' }}">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                </button>
            </form>
        </div>

        {# Description #}
        {% if task.description %}
        <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Description</p>
            <p class="text-gray-700 leading-relaxed whitespace-pre-line">{{ task.description }}</p>
        </div>
        {% endif %}

        {# Métadonnées #}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4 border-t border-gray-100">
            {% if task.dueDate %}
            <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Échéance</p>
                <p class="text-sm {{ task.isOverdue() ? 'text-red-600 font-medium' : 'text-gray-900' }}">
                    {{ task.dueDate|date('d/m/Y') }}
                </p>
            </div>
            {% endif %}
            <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Créée le</p>
                <p class="text-sm text-gray-900">{{ task.createdAt|date('d/m/Y à H:i') }}</p>
            </div>
            <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Modifiée le</p>
                <p class="text-sm text-gray-900">{{ task.updatedAt|date('d/m/Y à H:i') }}</p>
            </div>
        </div>
    </div>

    {# Actions #}
    <div class="flex items-center gap-3">
        <a href="{{ path('app_task_edit', {id: task.id}) }}" class="btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Modifier
        </a>
        <a href="{{ path('app_task_index') }}" class="btn-secondary">Retour</a>
        <div class="ml-auto">
            {% include 'task/_delete_form.html.twig' %}
        </div>
    </div>

</div>
{% endblock %}
