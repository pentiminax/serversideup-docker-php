<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}TaskFlow{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.bunny.net">
        <link href="https://fonts.bunny.net/css?family=inter:400,500,600,700&display=swap" rel="stylesheet">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✅</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
            <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
            <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
            <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <div class="flex h-screen overflow-hidden"
             data-controller="sidebar">

            {# Overlay mobile #}
            <div class="fixed inset-0 bg-black/40 z-20 lg:hidden hidden"
                 data-sidebar-target="overlay"
                 data-action="click->sidebar#close"></div>

            {# Sidebar #}
            {% block sidebar %}
                {% include '_sidebar.html.twig' %}
            {% endblock %}

            {# Main content #}
            <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
                {# Top bar mobile #}
                <header class="lg:hidden flex items-center gap-3 px-4 py-3 bg-white border-b border-gray-100 sticky top-0 z-10">
                    <button type="button"
                            data-action="sidebar#open"
                            class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors"
                            aria-label="Ouvrir le menu">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </button>
                    <span class="text-lg font-semibold text-gray-900">TaskFlow</span>
                </header>

                {# Flash messages #}
                {% include '_flash_messages.html.twig' %}

                {# Page content #}
                <main class="flex-1 overflow-y-auto" id="main-content">
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                        {% block body %}{% endblock %}
                    </div>
                </main>
            </div>
        </div>
    </body>
</html>
